{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode — Vite/esbuild resolves imports; tsc only type-checks. */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Incremental migration: .js and .ts coexist; .js files are resolved but
       not type-checked (checkJs:false) until they're converted to .ts/.tsx. */
    "allowJs": true,
    "checkJs": false,

    /* Type safety — strict on; the unused-locals checks are deferred until the
       App.tsx conversion lands so they don't block the migration. */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
