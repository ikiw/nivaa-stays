{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nivaastays",
  "main": "./_worker.js",
  "compatibility_date": "2026-04-25",
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": false
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
